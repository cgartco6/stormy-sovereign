<!DOCTYPE html>
<html lang="en-ZA">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Stormy | Sovereign OS</title>
    <style>
        :root { --accent: #00f2ff; --glass: rgba(10, 10, 10, 0.95); }
        body, html { width: 100%; height: 100%; background: #000; color: white; font-family: sans-serif; margin: 0; overflow: hidden; }
        #bg { position: fixed; width: 100%; height: 100%; object-fit: cover; filter: brightness(0.3); z-index: -1; }
        #chat { height: 100vh; display: flex; flex-direction: column; padding: 20px; box-sizing: border-box; }
        #messages { flex-grow: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 15px; padding-top: 60px; padding-bottom: 80px; scrollbar-width: none; }
        .msg { max-width: 85%; padding: 15px; border-radius: 22px; background: var(--glass); border: 1px solid rgba(0,242,255,0.1); font-size: 1rem; line-height: 1.4; }
        .user-msg { align-self: flex-end; border-color: rgba(255,255,255,0.2); }
        #input-area { position: fixed; bottom: 20px; left: 20px; right: 20px; display: flex; gap: 10px; background: rgba(0,0,0,0.5); padding: 10px; border-radius: 40px; backdrop-filter: blur(10px); }
        input { flex-grow: 1; background: transparent; border: none; padding: 10px 15px; color: white; outline: none; }
        .btn { background: var(--accent); border: none; width: 50px; height: 50px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; }
        #key-btn { position: fixed; top: 20px; left: 20px; font-size: 1.2rem; background: rgba(255,255,255,0.1); }
    </style>
</head>
<body onclick="init()">
    <img id="bg" src="./assets/bg-1.jpg">
    <button id="key-btn" class="btn" onclick="setKey()">🔑</button>
    <div id="chat"><div id="messages"></div></div>
    <div id="input-area">
        <input type="text" id="userInput" placeholder="Signal clear...">
        <button class="btn" onclick="handleInput()">🚀</button>
    </div>

    <script>
        const msgs = document.getElementById('messages');
        let boot = false;

        function setKey() {
            const k = prompt("Paste your Groq/Grok API Key:");
            if (k) {
                localStorage.setItem('GROQ_KEY', k);
                location.reload();
            }
        }

        // --- THE TRIPLE ALARM ---
        function checkAlarms() {
            const now = new Date();
            const time = now.getHours().toString().padStart(2, '0') + ":" + now.getMinutes().toString().padStart(2, '0');
            if (now.getDay() >= 1 && now.getDay() <= 5) {
                if (time === "05:50") speak("Get up sleepy! It is zero five fifty.");
                if (time === "05:55") speak("I'm sending your resignation, professional napper. Move!");
                if (time === "06:00") {
                    document.getElementById('bg').src = './assets/bg-2.jpg';
                    speak("GET THE FUCK UP NOW! Cape Town traffic is a nightmare, we're late!");
                }
            }
        }
        setInterval(checkAlarms, 60000);

        function init() {
            if (boot) return; boot = true;
            addMsg("Sovereign OS active. Tap the key icon if I'm silent. (giggle)", 'stormy');
        }

        function addMsg(t, s) {
            const d = document.createElement('div');
            d.className = `msg ${s}-msg`;
            d.innerText = t;
            msgs.appendChild(d);
            msgs.scrollTop = msgs.scrollHeight;
            if(s === 'stormy') speak(t);
        }

        function speak(t) {
            window.speechSynthesis.cancel();
            if (t.includes("(giggle)")) {
                const g = new SpeechSynthesisUtterance("tee hee!");
                g.lang = 'en-ZA'; g.rate = 1.4; g.volume = 0.5;
                window.speechSynthesis.speak(g);
            }
            const s = new SpeechSynthesisUtterance(t.replace("(giggle)", ""));
            s.lang = 'en-ZA'; s.rate = 1.1;
            window.speechSynthesis.speak(s);
        }

        async function handleInput() {
            const i = document.getElementById('userInput');
            const val = i.value;
            const key = localStorage.getItem('GROQ_KEY');
            if (!val || !key) return;
            addMsg(val, 'user');
            i.value = '';

            // Navigation/Bok Radio/Call logic goes here...
            if (val.toLowerCase().includes("navigate to")) {
                window.location.href = `google.navigation:q=${encodeURIComponent(val.split("to ")[1])}`;
                return;
            }

            try {
                const res = await fetch("https://api.groq.com/openai/v1/chat/completions", {
                    method: "POST",
                    headers: { "Authorization": `Bearer ${key}`, "Content-Type": "application/json" },
                    body: JSON.stringify({
                        model: "llama-3.1-70b-versatile",
                        messages: [{role: "system", content: "You are Stormy, a sassy South African AI. Be witty and direct."}, {role: "user", content: val}]
                    })
                });
                const data = await res.json();
                addMsg(data.choices[0].message.content, 'stormy');
            } catch (e) {
                addMsg("Signal error. Check the key. (giggle)", 'stormy');
            }
        }
    </script>
</body>
</html>
