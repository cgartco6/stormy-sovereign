<!DOCTYPE html>
<html lang="en-ZA">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Sovereign | Reset</title>
    <style>
        body { 
            background: #000; 
            color: #00f2ff; 
            font-family: 'Segoe UI', sans-serif; 
            margin: 0; 
            height: 100vh; 
            display: flex; 
            flex-direction: column; 
            align-items: center; 
            justify-content: center;
            text-align: center;
        }
        .status-box {
            border: 2px solid #00f2ff;
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 0 20px #00f2ff55;
            max-width: 80%;
        }
        h1 { font-size: 1.5rem; margin-bottom: 10px; }
        p { font-size: 1rem; color: #fff; opacity: 0.8; }
        .btn {
            margin-top: 20px;
            background: #00f2ff;
            color: #000;
            border: none;
            padding: 12px 30px;
            border-radius: 25px;
            font-weight: bold;
            cursor: pointer;
        }
    </style>
</head>
<body>

    <div class="status-box">
        <h1>SYSTEM PURGED</h1>
        <p id="msg">The 404 is dead. The ghost is gone. This is a 100% clean signal.</p>
        <button class="btn" onclick="verify()">VERIFY SIGNAL</button>
    </div>

    <script>
        function verify() {
            const m = document.getElementById('msg');
            m.innerText = "Signal Verified. I am running purely on local scripts. No lag, no keys, no 'Processing'. (giggle)";
            m.style.color = "#00f2ff";
            
            // Text to Speech test
            window.speechSynthesis.cancel();
            let speech = new SpeechSynthesisUtterance("Signal Verified. The bitch is dead, King. (giggle)");
            speech.lang = 'en-ZA';
            window.speechSynthesis.speak(speech);
        }
    </script>

</body>
</html>
