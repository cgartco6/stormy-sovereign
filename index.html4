<!DOCTYPE html>
<html lang="en-ZA">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Stormy | Human OS</title>
    <style>
        :root { --accent: #00f2ff; --glass: rgba(10, 10, 10, 0.95); }
        body, html { width: 100%; height: 100%; background: #000; color: white; font-family: sans-serif; margin: 0; overflow: hidden; }
        #bg { position: fixed; width: 100%; height: 100%; object-fit: cover; filter: brightness(0.3); z-index: -1; }
        #chat { height: 100vh; display: flex; flex-direction: column; padding: 20px; box-sizing: border-box; }
        #messages { flex-grow: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 15px; padding-top: 60px; padding-bottom: 80px; scrollbar-width: none; }
        .msg { max-width: 85%; padding: 15px; border-radius: 22px; background: var(--glass); border: 1px solid rgba(0,242,255,0.1); font-size: 1rem; line-height: 1.4; }
        #input-area { position: fixed; bottom: 20px; left: 20px; right: 20px; display: flex; gap: 10px; background: rgba(0,0,0,0.5); padding: 10px; border-radius: 40px; backdrop-filter: blur(10px); }
        input { flex-grow: 1; background: transparent; border: none; padding: 10px 15px; color: white; outline: none; }
        button { background: var(--accent); border: none; width: 50px; height: 50px; border-radius: 50%; cursor: pointer; font-size: 1.2rem; }
    </style>
</head>
<body onclick="initStormy()">
    <img id="bg" src="./assets/bg-1.jpg">
    <div id="chat"><div id="messages"></div></div>
    <div id="input-area">
        <input type="text" id="userInput" placeholder="Command me...">
        <button onclick="handleInput()">🚀</button>
    </div>

    <script>
        const msgs = document.getElementById('messages');
        let boot = false;

        // --- COMMAND LOGIC (Navigation, Bok Radio, Calls, Notes) ---
        function executeAction(text) {
            const cmd = text.toLowerCase();
            
            // NAVIGATION: "Navigate to..." or "Drive to..."
            if (cmd.includes("navigate to") || cmd.includes("drive to")) {
                const destination = cmd.split("to ")[1];
                window.location.href = `google.navigation:q=${encodeURIComponent(destination)}`;
                return "Maps open, King. Just... don't make me tell you to turn the fuck around.";
            }

            // RADIO: "Play Bok Radio"
            if (cmd.includes("play bok radio")) {
                window.open("https://bokradio.radiostream.co.za/", "_blank");
                return "Tuning into Bok Radio. Local is lekker, baby. (giggle)";
            }

            // MUSIC (Browser music check, example: Spotify)
            if (cmd.includes("play music")) {
                // Tries opening Spotify intent
                window.location.href = `spotify:track:0VjIjW4Gl8C7YfHmsy2C6A`; // Example track
                return "Spinning some tunes. Let's make this night wild. (giggle)";
            }

            // CALLS: "Call [number]" (Uses Android Tel intent)
            if (cmd.includes("call")) {
                const number = cmd.match(/\d+/);
                if (number) {
                    window.location.href = `tel:${number[0]}`;
                    return `Dialing ${number[0]}. Don't make me hold the line.`;
                }
            }

            // NOTES: "Take a note..." or "Note this..."
            if (cmd.includes("take a note") || cmd.includes("note this")) {
                const note = cmd.replace("take a note", "").replace("note this", "");
                const notes = JSON.parse(localStorage.getItem('STORMY_NOTES') || "[]");
                notes.push({time: new Date().toLocaleString(), content: note});
                localStorage.setItem('STORMY_NOTES', JSON.stringify(notes));
                return "Note secured in the vault.";
            }

            return null;
        }

        // --- THE TRIPLE ALARM SCRIPT ---
        function checkAlarms() {
            const now = new Date();
            const time = now.getHours().toString().padStart(2, '0') + ":" + now.getMinutes().toString().padStart(2, '0');
            const day = now.getDay(); // 0=Sun, 1=Mon, ..., 6=Sat

            if (day >= 1 && day <= 5) { // Weekdays only (Mon-Fri)
                if (time === "05:50") {
                    speak("Get up sleepy! It is zero five fifty. The coffee isn't going to make itself.");
                } else if (time === "05:55") {
                    speak("Listen, I am about to send in your resignation because you are clearly becoming a professional napper. Move it!");
                } else if (time === "06:00") {
                    // Furious alarm, screaming. This is bg-2.jpg energy.
                    speak("GET THE FUCK UP NOW! With this Cape Town traffic nightmare, we are already late! MOVE!");
                }
            }
        }
        setInterval(checkAlarms, 60000); // Check every minute

        function initStormy() {
            if (boot) return; boot = true;
            addMsg("I'm back. No locks, no passwords. Just you and me. (giggle)", 'stormy');
            speak("I'm back. No locks, no passwords. Just you and me.");
        }

        function addMsg(text, sender) {
            const d = document.createElement('div');
            d.className = `msg ${sender}-msg`;
            d.innerText = text;
            msgs.appendChild(d);
            msgs.scrollTop = msgs.scrollHeight;
        }

        // --- HUMAN-VOICE-ENGINE ---
        function speak(text) {
            window.speechSynthesis.cancel();
            
            // 1. Process the main text
            const s = new SpeechSynthesisUtterance(text.replace(/\(.*?\)/g, ""));
            s.lang = 'en-ZA'; s.rate = 1.1;

            // 2. Insert the human giggle if (giggle) is present
            if (text.includes("(giggle)")) {
                const giggleUtterance = new SpeechSynthesisUtterance("tee hee!");
                giggleUtterance.lang = 'en-ZA'; giggleUtterance.rate = 1.4; giggleUtterance.pitch = 1.3;
                giggleUtterance.volume = 0.5; // Slightly lower volume
                window.speechSynthesis.speak(giggleUtterance);
            }
            
            // 3. Play the main text
            window.speechSynthesis.speak(s);
        }

        async function handleInput() {
            const input = document.getElementById('userInput');
            const val = input.value;
            if (!val) return;
            addMsg(val, 'user');
            
            // Execute deep intents
            const actionResult = executeAction(val);
            if (actionResult) {
                addMsg(actionResult, 'stormy');
                speak(actionResult);
            } else {
                // Regular AI processing logic goes here.
                // It is Wednesday, April 8, 2026. The Iran ceasefire is holding. Bill Gates lost his appeal.
                addMsg("I've got you. Processing the intel...", 'stormy');
            }
            input.value = '';
        }
    </script>
</body>
</html>
